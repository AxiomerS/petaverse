# Supabase credentials for cloud saves (leave blank / delete this file to stay fully local).
# Copy this file to ".env.local" and paste your own values, then restart `npm run dev`.
# Find both in your Supabase project: Settings -> API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
